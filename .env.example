# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Supabase — from your project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Name of the table you created in Supabase
SUPABASE_TABLE=videos

# Whisper model size: tiny | base | small | medium | large
# tiny  = fastest, least accurate (~1x realtime on CPU)
# base  = good balance (default, ~2x realtime on CPU)
# small = more accurate, slower (~5x realtime on CPU)
WHISPER_MODEL=base

PORT=3000

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Rate limiting — max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# Max concurrent video processing jobs
MAX_CONCURRENT_JOBS=2

# Telegram bot (required for Cloud Run, optional for local dev)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
